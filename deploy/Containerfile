# Multi-stage build for the Linea server.

FROM golang:1.25-alpine AS build
WORKDIR /src

# Cache deps
COPY go.mod go.sum ./
RUN go mod download

# Build
COPY . .
ARG VERSION=0.1.0-dev
RUN CGO_ENABLED=0 go build \
    -trimpath \
    -ldflags "-s -w -X main.version=${VERSION}" \
    -o /out/lineasrv \
    ./cmd/lineasrv

# Runtime: distroless
FROM gcr.io/distroless/static-debian12:nonroot
WORKDIR /app

COPY --from=build /out/lineasrv /usr/local/bin/lineasrv

ENV LINEA_DATA_DIR=/data \
    LINEA_GRPC_ADDR=":9090" \
    LINEA_HTTP_ADDR=":8080"

EXPOSE 8080 9090
VOLUME /data
USER nonroot:nonroot

ENTRYPOINT ["/usr/local/bin/lineasrv"]
