{
  "realm": "linea",
  "enabled": true,
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,

  "groups": [
    { "name": "linea-viewer" },
    { "name": "linea-contributor" },
    { "name": "linea-curator" }
  ],

  "clients": [
    {
      "clientId": "linea-cli",
      "enabled": true,
      "publicClient": true,
      "directAccessGrantsEnabled": true,
      "standardFlowEnabled": true,
      "redirectUris": ["http://localhost:8080/*"],
      "webOrigins": ["+"],
      "protocol": "openid-connect",
      "attributes": {
        "post.logout.redirect.uris": "+"
      },
      "protocolMappers": [
        {
          "name": "groups",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-group-membership-mapper",
          "config": {
            "claim.name": "groups",
            "full.path": "false",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        },
        {
          "name": "audience-linea-cli",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "config": {
            "included.client.audience": "linea-cli",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        }
      ]
    }
  ],

  "users": [
    {
      "username": "viewer",
      "enabled": true,
      "email": "viewer@example.com",
      "emailVerified": true,
      "credentials": [{ "type": "password", "value": "viewer", "temporary": false }],
      "groups": ["/linea-viewer"]
    },
    {
      "username": "author",
      "enabled": true,
      "email": "author@example.com",
      "emailVerified": true,
      "credentials": [{ "type": "password", "value": "author", "temporary": false }],
      "groups": ["/linea-contributor"]
    },
    {
      "username": "curator",
      "enabled": true,
      "email": "curator@example.com",
      "emailVerified": true,
      "credentials": [{ "type": "password", "value": "curator", "temporary": false }],
      "groups": ["/linea-curator"]
    }
  ]
}
